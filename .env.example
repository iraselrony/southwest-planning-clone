# --- Payload CMS ---
# Neon Postgres — pooled connection (used at runtime for queries)
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Neon Postgres — direct/unpooled connection (used for migrations)
DIRECT_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# Vercel Blob token (https://vercel.com/dashboard -> Storage -> Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_xxx
# Payload JWT secret (run: openssl rand -hex 32)
PAYLOAD_SECRET=replace_with_64_char_random_hex_string
# Public URL of the deployed site (no trailing slash)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Resend (existing contact form) ---
RESEND_API_KEY=re_xxx
CONTACT_TO_EMAIL=info@southwestplanningconsultancy.co.uk
CONTACT_FROM_EMAIL=onboarding@resend.dev
