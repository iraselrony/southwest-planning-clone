{
  "name": "southwest-planning-clone",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 3000",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start -p 3000",
    "lint": "next lint",
    "extract": "node scripts/extract-inventory.mjs",
    "generate-routes": "node scripts/generate-routes.mjs",
    "visual-diff": "node scripts/visual-diff.mjs",
    "verify": "node scripts/verify.mjs",
    "verify:payload": "node scripts/verify-payload.mjs",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "migrate:create": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:create",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "migrate:fresh": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:fresh",
    "migrate:status": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:status",
    "seed:pages": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/seed-pages.mjs",
    "seed:services": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/seed-services.mjs",
    "seed:settings": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/seed-site-settings.mjs",
    "seed:zones": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/seed-initial-zones.mjs",
    "seed:all": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/seed-all.mjs",
    "migrate:assets": "node scripts/migrate-assets-to-blob.mjs",
    "mark:zones": "node scripts/mark-zones.mjs"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.85.1",
    "@payloadcms/next": "^3.85.1",
    "@payloadcms/richtext-lexical": "^3.85.1",
    "@payloadcms/storage-vercel-blob": "^3.85.1",
    "graphql": "^17.0.1",
    "isomorphic-dompurify": "2.19.0",
    "next": "15.3.9",
    "payload": "^3.85.1",
    "pg": "^8.22.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "resend": "^6.14.0",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@types/pg": "^8.20.0",
    "@types/react": "19.0.4",
    "@types/react-dom": "19.0.2",
    "cheerio": "1.0.0",
    "cross-env": "^10.1.0",
    "fast-glob": "3.3.3",
    "playwright": "1.49.1",
    "typescript": "5.7.3"
  }
}
